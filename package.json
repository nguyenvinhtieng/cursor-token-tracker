{
  "name": "cursor-usage-tracker",
  "displayName": "Cursor Token Tracker",
  "description": "Show Cursor AI spend and tokens in the status bar",
  "version": "0.1.5",
  "publisher": "nguyenvinhtieng",
  "author": {
    "name": "nguyenvinhtieng.vn"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nguyenvinhtieng/cursor-token-tracker"
  },
  "homepage": "https://github.com/nguyenvinhtieng/cursor-token-tracker#readme",
  "bugs": {
    "url": "https://github.com/nguyenvinhtieng/cursor-token-tracker/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorUsage.refresh",
        "title": "Cursor Usage: Refresh"
      },
      {
        "command": "cursorUsage.setToken",
        "title": "Cursor Usage: Set Session Token"
      },
      {
        "command": "cursorUsage.resetSession",
        "title": "Cursor Usage: Reset Chat Session"
      },
      {
        "command": "cursorUsage.showDetails",
        "title": "Cursor Usage: Show Details"
      },
      {
        "command": "cursorUsage.openDashboard",
        "title": "Cursor Usage: Open Dashboard"
      },
      {
        "command": "cursorUsage.diagnoseAuth",
        "title": "Cursor Usage: Diagnose Auth"
      },
      {
        "command": "cursorUsage.clearToken",
        "title": "Cursor Usage: Clear Saved Token"
      },
      {
        "command": "cursorUsage.exportCsv",
        "title": "Cursor Usage: Export CSV"
      },
      {
        "command": "cursorUsage.exportJson",
        "title": "Cursor Usage: Export JSON"
      },
      {
        "command": "cursorUsage.openTranscript",
        "title": "Cursor Usage: Open Transcript"
      },
      {
        "command": "cursorUsage.history.filterPeriod",
        "title": "Filter by Period",
        "icon": "$(calendar)"
      },
      {
        "command": "cursorUsage.history.filterModel",
        "title": "Filter by Model",
        "icon": "$(filter)"
      },
      {
        "command": "cursorUsage.history.clearFilters",
        "title": "Clear Filters",
        "icon": "$(clear-all)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "cursorUsageHistory",
          "name": "Usage History",
          "when": "workspaceFolderCount >= 0"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorUsage.history.filterPeriod",
          "when": "view == cursorUsageHistory",
          "group": "navigation@1"
        },
        {
          "command": "cursorUsage.history.filterModel",
          "when": "view == cursorUsageHistory",
          "group": "navigation@2"
        },
        {
          "command": "cursorUsage.history.clearFilters",
          "when": "view == cursorUsageHistory",
          "group": "navigation@3"
        },
        {
          "command": "cursorUsage.exportCsv",
          "when": "view == cursorUsageHistory",
          "group": "navigation@4"
        },
        {
          "command": "cursorUsage.exportJson",
          "when": "view == cursorUsageHistory",
          "group": "navigation@5"
        },
        {
          "command": "cursorUsage.refresh",
          "when": "view == cursorUsageHistory",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "cursorUsage.openTranscript",
          "when": "view == cursorUsageHistory && viewItem == usageEvent"
        }
      ]
    },
    "configuration": {
      "title": "Cursor Usage Tracker",
      "properties": {
        "cursorUsage.refreshIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "description": "Refresh interval in seconds"
        },
        "cursorUsage.autoDetectToken": {
          "type": "boolean",
          "default": true,
          "description": "Automatically read token from Cursor state.vscdb"
        },
        "cursorUsage.displayFormat": {
          "type": "string",
          "enum": [
            "compact",
            "full"
          ],
          "default": "compact",
          "description": "Deprecated — use individual status bar toggles in Settings"
        },
        "cursorUsage.showMonthlySpend": {
          "type": "boolean",
          "default": true,
          "description": "Show monthly spend ($used/$budget) on the status bar"
        },
        "cursorUsage.showBudgetRemaining": {
          "type": "boolean",
          "default": true,
          "description": "Show remaining budget ($X left) on the status bar"
        },
        "cursorUsage.showTodaySpend": {
          "type": "boolean",
          "default": true,
          "description": "Show today's spend on the status bar"
        },
        "cursorUsage.showChatSession": {
          "type": "boolean",
          "default": false,
          "description": "Show current chat session spend on the status bar"
        },
        "cursorUsage.showWorkspaceAggregate": {
          "type": "boolean",
          "default": true,
          "description": "Show per-workspace usage breakdown in tooltip and detail panel when multiple folders are open"
        },
        "cursorUsage.showTokens": {
          "type": "boolean",
          "default": true,
          "description": "Show token counts on today and chat segments in the status bar"
        },
        "cursorUsage.monthlyBudget": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "Monthly spending limit in USD (shown as $used/$limit in status bar)"
        },
        "cursorUsage.activeChatRefreshSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "description": "Refresh interval in seconds while a chat session is active"
        },
        "cursorUsage.showBudgetPercent": {
          "type": "boolean",
          "default": true,
          "description": "Show budget usage percentage in status bar"
        },
        "cursorUsage.chatSessionAlertThreshold": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Alert when current chat session spend reaches this USD amount (0 = disabled). Shown on a separate status bar item."
        },
        "cursorUsage.chatAlertBackground": {
          "type": "string",
          "enum": [
            "prominent",
            "warning",
            "error"
          ],
          "default": "error",
          "description": "Status bar background for chat session alert (separate from monthly budget warning colors)"
        },
        "cursorUsage.stateDbPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to Cursor state.vscdb (leave empty for auto-detect)"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.vsix",
    "package": "npm run compile && vsce package",
    "install:local": "cursor --install-extension $(ls -t *.vsix | head -n1)",
    "buildinstall": "npm run clean && npm run package && npm run install:local",
    "version:patch": "npm version patch -m \"chore(release): v%s\"",
    "version:minor": "npm version minor -m \"chore(release): v%s\"",
    "version:major": "npm version major -m \"chore(release): v%s\"",
    "publish": "vsce publish",
    "publish:patch": "vsce publish patch -m \"chore(release): v%s\"",
    "publish:minor": "vsce publish minor -m \"chore(release): v%s\"",
    "publish:major": "vsce publish major -m \"chore(release): v%s\"",
    "release": "npm run compile && vsce publish",
    "release:patch": "npm run version:patch &&npm run compile && vsce publish",
    "release:minor": "npm run version:minor &&npm run compile && vsce publish",
    "release:major": "npm run version:major &&npm run compile && vsce publish",
    "gh-release": "npm run package && gh release create v$npm_package_version $(ls -t *.vsix | head -n1) --title \"v$npm_package_version\" --generate-notes",
    "gh-release:patch": "npm run version:patch && npm run gh-release",
    "gh-release:minor": "npm run version:minor && npm run gh-release",
    "gh-release:major": "npm run version:major && npm run gh-release"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  }
}
